# # Add the specific blobs your hardware needs (Example for Intel Laptops)
# # Space-separated list relative to /lib/firmware
# FW_LIST="i915/adlp_dmc.bin iwlwifi-ty-a0-gf-a0-59.ucode" 
# $CONF --set-str CONFIG_EXTRA_FIRMWARE "$FW_LIST"
#$CONF --set-str CONFIG_LOCALVERSION "-$VERSION"


add_firmware() {
  ensure_firmware_apt_sources

  $APTINSTALL firmware-linux-free firmware-ath9k-htc  firmware-misc-nonfree   firmware-realtek firmware-brcm80211  \
    firmware-sof-signed \
    firmware-intel-sound \
    firmware-iwlwifi \
    firmware-linux-nonfree \
    firmware-nvidia-gsp

  # if [ ! -f ${out}/img/firmware.erofs ]; then
    #(
     # cd ${out}
      # git clone https://git.kernel.org/pub/scm/linux/kernel/git/firmware/linux-firmware.git
      # mkdir firmware
      # cd linux-firmware
      # ./copy-firmware.sh ../firmware
      # cd ../firmware
      #mkfs.erofs -zlz4 ${out}/img/firmware.erofs    
    #)
  # fi
  (cd /lib/firmware &&  mkfs.erofs -zlz4 ${out}/img/firmware.erofs . )

  

  # $APTINSTALL \
  #   firmware-linux-free firmware-ath9k-htc   \
  #   firmware-misc-nonfree firmware-iwlwifi \
  #   firmware-realtek firmware-brcm80211
}

# Adds Nvidia driver.
nvidia() {
  cd ${out}

  cd open-gpu-kernel-modules
  export SYSSRC=${out}/linux
  make SYSSRC=${out}/linux SYSOUT=${out}/linux
  make modules_install
}

"$@"
