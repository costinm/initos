  $APTINSTALL firmware-linux-free firmware-ath9k-htc  firmware-misc-nonfree   firmware-realtek firmware-brcm80211  \
    firmware-sof-signed \
    firmware-intel-sound \
    firmware-iwlwifi \
    firmware-linux-nonfree \
    firmware-nvidia-gsp

  # if [ ! -f ${out}/img/firmware.erofs ]; then
    #(
     # cd ${out}
      # git clone https://git.kernel.org/pub/scm/linux/kernel/git/firmware/linux-firmware.git
      # mkdir firmware
      # cd linux-firmware
      # ./copy-firmware.sh ../firmware
      # cd ../firmware
      #mkfs.erofs -zlz4 ${out}/img/firmware.erofs    
    #)
  # fi
  (cd /lib/firmware &&  mkfs.erofs -zlz4 ${out}/img/firmware.erofs . )

  

  # $APTINSTALL \
