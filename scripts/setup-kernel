#!/bin/bash

################# Kernel building #######################################
# This script runs inside a container (userspace podmain) or on a VM/host 
# with all dependencies available - either debian or nix:
# 
# ${src} contains the initos repo - in container should be same dir as on the host
# ${out} defaults to ${src}/target
#
# The script has functions to install deps, firmware and clone the source and
# build - using a debian base config plus fragments adding extra buildt-in modules
# to avoid initrd.
#
# ${out}/linux will have the linux source tree
# ${out}/open-gpu-kernel-modules will have the nvidia driver source tree
# ${out}/img/ will have the output files, including erofs with modules, bzImage.
#
# An alternative is to use the nix flake under linux - which is using the sources
# from Nix instead of getting from upstream git.
# 
# Both produce similar output - and need to verify both work, Nix may be
# 'verifiable' at build level - not on the content of the source files and any
# patches or scripts used.

set -x
set -e
export DEBIAN_FRONTEND=noninteractive
APTINSTALL='apt install -o Dpkg::Options::=--force-confold --assume-yes --no-install-recommends '

BRANCH=${BRANCH:-6.18}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

src=${src:-${PROJECT_ROOT}}
if [[ ! "$src" =~ ^/ ]]; then
    src="$(pwd)/$src"
fi
out=${out:-${src}/target}
if [[ ! "$out" =~ ^/ ]]; then
    out="$(pwd)/$out"
fi

ensure_firmware_apt_sources() {
  local changed=0
  local f

  if grep -RqsE '^(Components:|deb .* )[[:alnum:][:space:]_-]*non-free-firmware' \
      /etc/apt/sources.list /etc/apt/sources.list.d 2>/dev/null; then
    return 0
  fi

  for f in /etc/apt/sources.list.d/*.sources; do
    [ -f "$f" ] || continue
    sed -i '/^Components:/ {
      / contrib/! s/$/ contrib/
      / non-free/! s/$/ non-free/
      / non-free-firmware/! s/$/ non-free-firmware/
    }' "$f"
    changed=1
  done

  if [ -f /etc/apt/sources.list ]; then
    sed -i '/^deb / {
      / contrib/! s/ main/ main contrib/
      / non-free/! s/ main/ main non-free/
      / non-free-firmware/! s/ main/ main non-free-firmware/
    }' /etc/apt/sources.list
    changed=1
  fi

  if [ "$changed" = 1 ]; then
    apt update
  fi
}


get_kernel() {
  cd ${out}
  git clone --depth=1 --branch linux-${BRANCH}.y --single-branch https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git linux
}

all() {
  kernel_build
  kernel_pack
}


kernel_pack() {
  dest=${dest:-${out}/opt/kernel-image}
  mkdir -p ${dest}
  cp ${out}/linux/arch/x86/boot/bzImage ${dest}/bzImage
  cp ${out}/linux/.config ${dest}/.config
  VER=$(cat ${out}/linux/include/config/kernel.release)
  (cd /lib/modules/${VER} && mkfs.erofs -zlz4 ${dest}/modules-${VER}.erofs .)
}

# Get the kernel and nvidia from git, apply patches, build
# Requires a host that is setup with setup-deb kernel_build_tools
# or a nix env with equivalent configs.
kernel() {

  #rm -rf /lib/modules/*
  if [ ! -e ${out}/linux ] ; then
    get_kernel
  else 
    cd ${out}/linux
    git pull 
  fi

  kernel_build

    # Will use systemd or script - may start it as 'main' as well, without
  # an actual sidecar.
  # Not the current kernel on the builder machine
  if [ ! -e open-gpu-kernel-modules ]; then 
    git clone https://github.com/NVIDIA/open-gpu-kernel-modules.git
  else 
    (cd open-gpu-kernel-modules &&  git pull)
  fi
  nvidia

  kernel_pack
}


CONF="./scripts/config"
BUILTIN="./scripts/config --enable "
MOD="./scripts/config --module "

kernel_cfg() {
  cd ${out}/linux

  # load debian and apply overrides.
  cp  ${src}/linux/${BRANCH}/config.amd64 .config 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/${BRANCH}/config
    
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/builtins.fragment 
  
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/filesystems.fragment 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/crypto.fragment   
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/containers.fragment 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/net.fragment 
  
  # Only on host
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/block.fragment 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/usb.fragment 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/networking.fragment 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/mods2.fragment 
  
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/efi.fragment 

  # One of the laptops was not covered by debian selection
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/host-lenovo.fragment 
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/cros/hatch.fragment
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/host-chromeos.fragment 

  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/tpm2.fragment 
  # Host display - VMs are different
  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/display.fragment 

  ./scripts/kconfig/merge_config.sh -m .config ${src}/linux/y-remove.fragment 
 
  # Synchronize config
  make olddefconfig
  
}


kernel_build() {
  kernel_cfg
  make -j$(($(nproc) * 2 + 1))

  make modules -j$(($(nproc) * 2 + 1))
  make modules_install

}

