  if [ ! -e open-gpu-kernel-modules ]; then 
    git clone https://github.com/NVIDIA/open-gpu-kernel-modules.git
  fi
  cd open-gpu-kernel-modules
  export SYSSRC=${out}/linux
  make SYSSRC=${out}/linux SYSOUT=${out}/linux
  make modules_install

 # $APTINSTALL dkms nvidia-kernel-source nvidia-cuda-toolkit
 
#   scripts/config --disable CONFIG_LOCKDEP
