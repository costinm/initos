timeout: 0
serial: yes
graphics: no
verbose: yes
editor_enabled: no

/Boot-signed
  protocol: linux
  cmdline: INITOS_PUB_KEY=${INITOS_PUB_KEY} console=ttyS0 net.ifnames=0 panic=5 loglevel=6   
  path: boot():/EFI/LINUX/bzImage
  #${SHA_BZIMAGE}
  module_path: boot():/EFI/LINUX/initrd.img
  #${SHA_INITRD}
  
