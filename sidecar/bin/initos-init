#!/opt/busybox/bin/sh

export PATH=/opt/initos/bin:/opt/busybox/bin:/z/a/initos/bin:/bin:/sbin:/usr/bin:/usr/sbin
ver=$(uname -r)

if [ "${initos_dbg}" = 1 ]; then
  set -x
  #sysctl -w kernel.printk="0 4 1 7" > /dev/null 2>&1
fi

#### Helpers.

logi() {
	echo "INITOS: $*" > /dev/kmsg
}

lfatal() {
	echo "INITOS: FATAL: $*" > /dev/kmsg
  sleep 10
  reboot -f
}

# ovl mounts an image named $1 from /z/img/$n.erofs to /z/a/$n 
# as overlayfs. RW data will be in /z/initos/rw/$n
# 
# /z is the main ext4 drive and is R/W.
ovl() {
    local n=$1
    local dst=${2:-/z/a/${n}}

    local OVL_BASE=/z/initos
    if [ -d /z/c/mnt ]; then
       OVL_BASE=/z/c
    fi

    local f=/z/img/$n.erofs
    if [ ! -e "$f" ]; then
      f=/x/img/$n.erofs
    fi
    if [ ! -e "$f" ]; then
      f=/data/img/$n.erofs
    fi

    # TODO: use mnt to mount ro
    
    mkdir -p ${dst} ${OVL_BASE}/mnt/$n/ro ${OVL_BASE}/mnt/$n/rw ${OVL_BASE}/mnt/$n/work

    mount ${f} ${OVL_BASE}/mnt/$n/ro

    mount -t overlay \
        -o lowerdir=${OVL_BASE}/mnt/$n/ro,upperdir=${OVL_BASE}/mnt/$n/rw,workdir=${OVL_BASE}/mnt/$n/work \
        overlayfs ${dst}
}

# Mount an erofs file - no overlay
mnt() {
    local n=$1
    local dst=${2:-/z/a/${n}}

    local f=/z/img/$n.erofs
    if [ ! -e "$f" ]; then
      f=/x/img/$n.erofs
    fi
    if [ ! -e "$f" ]; then
      f=/data/img/$n.erofs
    fi

    # TODO: verify the image signature with the rust binary !!!

    mkdir -p ${dst}
    
    mount ${f} ${dst}
}


#### Steps of the boot


mount_sys() {
    local b=${1:-}
    mount -o noexec,nosuid,mode=0755 -t devtmpfs devtmpfs ${b}/dev || true


    mount -o noexec,nosuid,nodev -t proc proc ${b}/proc 2>/dev/null || true
    mount -o noexec,nosuid,nodev -t sysfs sysfs ${b}/sys 2>/dev/null || true

    mkdir -p ${b}/dev/pts ${b}/dev/shm
    #mount -t devpts -o gid=5,mode=0620,noexec,nosuid devpts /dev/pts
    mount -t devpts devpts ${b}/dev/pts
    mount -t tmpfs tmpfs ${b}/run
    mount -t tmpfs tmpfs ${b}/dev/shm

    mkdir -p ${b}/sys/fs/cgroup
    mount -t cgroup2 none ${b}/sys/fs/cgroup

#   mount -t devtmpfs -o exec,nosuid,mode=0755,size=2M devtmpfs /dev 2>/dev/null \
#     || mount -t tmpfs -o exec,nosuid,mode=0755,size=2M tmpfs /dev && mdev -f -s

    # Only on RO rootfs.
    # mount -t tmpfs tmpfs ${b}/tmp

    # Mount points even on RO rootfs.
    mount -t tmpfs tmpfs ${b}/mnt
    mount -t tmpfs tmpfs ${b}/tmp

    chmod 1777 ${b}/dev/shm
    chmod 1777 ${b}/run
    chmod 1777 ${b}/tmp

    mkdir -p ${b}/run/user
    chmod 1777 ${b}/run/user
    for i in 1000 1001 1002 1003 1004 1005 ; do
      mkdir ${b}/run/user/$i
      chmod 700 ${b}/run/user/$i
      chown $i ${b}/run/user/$i
    done

}

# Mounts the main ext4 drive as /z
# This requires the sys files to be mounted - modules not used.
init_ext4_data_dir() {
    # PARTLABEL doesn't work with busybox mount
    mount -o rw,noatime -O encrypt,verity LABEL=${INITOS_DATA:-STATE} /z
}


# Mount modules and firmware (readonly) - after STATE is mounted
# Should use verity and signatures for verified boot (WIP).
mount_modules() {
    mnt firmware /lib/firmware
    # /usr/lib/modules or /lib/modules are RO.
    # Need to mount as a tmpfs or sep 
    mkdir -p /z/a/modules/${ver}
    # Needs to be overlay - depmod is still used
    # TODO: rm -rf /z/mnt/... - no leftovers 
    ovl modules-${ver} /z/a/modules/${ver}

    # Need hwdrivers to unlock home
    mount --bind /z/a/modules /lib/modules
    mount --bind /z/a/modules/${ver} /lib/modules/${ver}
}

## Ask for a password, load the password to the kernel ring.
# The password may be used by multiple directories - it is not per dir.
#
unlock_c_pass() {
    local dir=${1:-/z/c}

    # While encrypting with a user key is possible and simple,
    # changing the key is very hard.
    # Fscrypt CLI is also using this model - but with a root directory (.fscrypt)
    # and different mechanism.
    if [ -f /z/initos/c.age ]; then
	    echo "Enter host unlock password:"
	    read -s -r KEY 2>/dev/null
              
      FSCRYPT_KEY=$(initos decrypt < /z/initos/c.age)
      unset KEY
              
	    if initos fscrypt /z/c; then
          unset FSCRYPT_KEY
          echo "Unlocked /z/c using age"
          return 0
      fi
    else
	    echo "Enter host unlock password:"
	    read -s -r FSCRYPT_KEY 2>/dev/null
      initos fscrypt ${dir}
    fi
            
    unset FSCRYPT_KEY
}

unlock_home() {
	unlock_home_pass
}

setup_c() {
    unlock_home_pass
}

# Adds a key to the keyring - unlocks all dirs in the filesystem using that key !
# This is not specific to a dir.
unlock_home_pass() {
    local dir=${1:-/z/c}
    if [ ! -d ${dir} ]; then
      echo "Not found - setup it first"
      return
    fi

    for i in 1 2 3; do
      echo "Enter crypt password:"
      read -s -r FSCRYPT_KEY 2>/dev/null || true
      if [ -n "${FSCRYPT_KEY}" ]; then
          export FSCRYPT_KEY
          if initos fscrypt ${dir} ; then
              break
          else
              echo "Failed to unlock, try again."
          fi
      fi
    done
    unset FSCRYPT_KEY
}

# Scan /sys for 'modalias', sort and load the modules.
# This should load TPM if it is available.
# Very heavy, only needed for finding the TPM driver.
hwdrivers() {
  for i in $(find /sys -name modalias -type f -print0 | xargs -0 cat  ) ; do modprobe $i ; done
  # busybox modprobe doesn't support -b
  #find /sys -name modalias -type f -print0 | xargs -0 sort -u | xargs modprobe -b -a
}

# After mounting /lib/modules and firmware, load all drivers.
load_drivers() {
  sysctl -w kernel.printk="0 4 1 7" > /dev/null 2>&1
  # this is normally done by sysinit - we want tpm2 to be loaded
  # Needs to happen after full firmware and modules are in place
  hwdrivers > /tmp/hwdrivers.log 2>&1
  hwdrivers > /tmp/hwdrivers2.log 2>&1 # TPM seems to need some time to init
  sysctl -w kernel.printk="2 4 1 7" > /dev/null 2>&1
}

# Unlock the host-encrypted directory using TPM.
# Requires loading the modules first (still working on getting all
# in the kernel).
unlock_c_tpm() {
    TPM_DIR=/z/initos/tpm

    # fscrypt: use TPM if available, otherwise prompt for password
    for i in 1 2 3; do
        if [ -e /dev/tpmrm0 ]; then
          # Will use /z/initos/tpm dir to find the handle id.
          if TPM_KEY=$(initos unseal); then
            echo "Unsealed TPM key ${TPM_KEY}"

            if [ -f /z/initos/c.age ]; then
              FSCRYPT_KEY=$(initos decrypt < /z/initos/c.age)
              mkdir -p /run/secrets/root
              echo "${FSCRYPT_KEY}" > /run/secrets/root/c_key
              chmod 600 /run/secrets/root/c_key
              KEY_FILE=/run/secrets/root/c_key
              if initos fscrypt /z/c; then
                echo "Unlocked /z/c using TPM + age"
                break
              fi
            else
              FSCRYPT_KEY=${TPM_KEY}
              if initos fscrypt /z/c; then
                echo "Unlocked /z/c using raw TPM"
                break
              fi
            fi
          fi
          echo "Failed to unseal using TPM"
          break
        else
          echo "TPM not found, waiting"
          sleep 5
        fi
    done
}

# Pivot to a different rootfs image, based on an overlay with
# a (verified) image and a writable layer under the encrypted disk.
#
# It is also possible to mount usr and var and keep the original 
# read-only root.
init_rootfs() {
    local name=${INITOS_ROOT:-ROOTA}

    modprobe squashfs

    if [ -e /z/c/roots/${name} ] ; then
      mount -o bind /z/c/roots/${name} /sysroot
      echo "mounted expanded encrypted root"
    else 
      ovl ${name} /sysroot
    fi

    cd /sysroot

    # mnt/initos is the old root - still has mounts

    echo Before pivot

    move_mounted_to_sysroot
    mkdir -p mnt/initos
    pivot_root . mnt/initos
    cd /

    echo "After pivot"

    # Make sure rootfs is mapped.
    mkdir -p  /lib/firmware /lib/modules/${ver}
    ovl firmware /usr/lib/firmware
    ovl modules-${ver} /lib/modules/${ver}

    if [ -d /z/c/home ]; then
      mkdir -p /z/c/initos/mnt
      mount -o bind /z/c/home /home
      mount -o bind /z/c/home/root /root
    fi

    ## mount -o bind /mnt/initos/modules/${ver} /lib/modules/${ver}
    ## mount -o bind /mnt/initos/firmware /lib/firmware

    mkdir -p /opt/busybox
    mount -o bind /mnt/initos/opt/busybox /opt/busybox
    mkdir -p /opt/initos
    mount -o bind /mnt/initos/opt/initos /opt/initos

    chmod 1777 /run
    chmod 1777 /tmp
}

# All remaining mounted dirs will be moved under same dir in /sysroot,
# ready to switch_root
move_mounted_to_sysroot() {
  # From original alpine init
  while read DEV DIR TYPE OPTS ; do
    case "$DIR" in
      /|/sysroot|/sysroot/*) continue ;;
    esac

    if [ -d "$DIR" ]; then
      echo "Moving $DIR to /sysroot$DIR"
      mkdir -p "/sysroot${DIR}"
      mount -o move "$DIR" "/sysroot${DIR}"
    fi
  done < /proc/mounts

  sync
}

# Finish init by giving control (exec) to a real init.
end_init() {
  cp -a /z/c/initos/etc/* /etc
  
  # Just to be sure
  chgrp shadow /etc/shadow /usr/sbin/unix_chkpwd
  chmod u+s /usr/sbin/unix_chkpwd
 
  mount --bind /z/flatpak /var/lib/flatpak
  mount --bind /z/nix /nix
  mount --bind /z/ws /ws
  if [ -f /z/c/initos/init ]; then
      /z/c/initos/init
  fi
  if [ -f /z/c/start ]; then
      exec /z/c/start
  fi

  if [ -f /lib/systemd/systemd ]; then
    exec /lib/systemd/systemd --system 
    #  systemd --log-level=err --unit=rescue.target --system --default-standard-output=tty --default-standard-error=tty
  elif [ -f /sbin/init ]; then
    exec /sbin/init
  fi
  if [ -f /sbin/openrc ]; then
    # Not using init - openrc (like s5) is just a launcher for 
    # initialization scripts.
    /sbin/openrc sysinit
    /sbin/openrc boot

    # Normall init starts this with 'wait'
    /sbin/openrc default
    ifconfig -a
    cat /etc/ssh/*.pub 
  fi

  echo "No init"
  # Note that load_drivers was NOT called.
  # TODO: if secure boot, fail.
  exec start_root system 1000
}

### Additional host functions


## If a 'vfio' file is configured, use it to move devices to 
# vfio-pci before loading the modules.
vfio() {
  if [ -f /z/initos/vfio ]; then

    modprobe vfio_iommu_type1  allow_unsafe_interrupts
    modprobe vfio_pci

    # Bind nvidia to vfio-pci - this will break Nvidia.
    # TODO: use a file or read a key to control. Screen will freeze.
    #  lspci -n -s 0x:0x.0 to find the vendor ID

    set -x
    read -t 2 -n 1 key
    if [ ! "$key" = "t" ]; then
      while read V1 V2 ; do
        echo "$V1" "$V2" > /sys/bus/pci/drivers/vfio-pci/new_id
      done < /z/initos/vfio
    fi
  fi
  # Alternatively, options vfio-pci ids=10de:1f82,10de:10fa
  # in /etc/modprobe.d - but I think this is more reliable.
  #echo 10de 1f82 > /sys/bus/pci/drivers/vfio-pci/new_id &
  #echo 10de 10fa > /sys/bus/pci/drivers/vfio-pci/new_id &
  # Second device: # echo 0000:02:00.0 > /sys/bus/pci/drivers/vfio-pci/bind
}

poweroff() {
    echo o > /proc/sysrq-trigger 2>/dev/null
}


#### Entry point

if [ "$$" = "1" ] && [ $# -eq 0 ]; then
  mount_sys
  init_ext4_data_dir

  mount_modules

  unlock_home

  init_rootfs

  end_init
else
  "$@"
fi
