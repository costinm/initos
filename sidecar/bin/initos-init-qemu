#!/opt/busybox/bin/sh
#
# Test script - will run in Qemu for integration/e2e testing.


export PATH=/opt/initos/bin:/opt/busybox/bin:/z/a/initos/bin:/bin:/sbin:/usr/bin:/usr/sbin

export initos_dbg=1
set -x

TPM_TEST_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
TPM_UNLOCK_FILE=/z/c/qemu-tpm-unlock.txt
TPM_UNLOCK_TEXT="tpm-initrd-unlock-ok"
QEMU_MODE_FILE=/z/qemu-test-mode

qemu_mode() {
    cat "${QEMU_MODE_FILE}" 2>/dev/null || echo basic
}

run_tpm_setup() {
    echo "=== INITRD TPM UNLOCK SETUP ==="
    mkdir -p /z/initos/tpm /z/c

    initos primary
    echo "primary exit=$?"
    echo "primary handle=0x81000000"

    initos seal "${TPM_TEST_KEY}"
    echo "seal exit=$?"
    echo "sealed handles dev=0x81001002 secure=0x81001003"

    FSCRYPT_KEY="${TPM_TEST_KEY}" initos fscrypt-setup /z/c
    echo "fscrypt-setup (/z/c tpm) exit=$?"

    mkdir -p /z/c/home/root
    mkdir -p /z/c/nix
    echo "${TPM_UNLOCK_TEXT}" > "${TPM_UNLOCK_FILE}"
    echo "initos-qemu-root-bind-ok" > /z/c/home/root/bind-check.txt
    echo "initos-qemu-nix-bind-ok" > /z/c/nix/bind-check.txt
    sync

    if [ "$(cat "${TPM_UNLOCK_FILE}" 2>/dev/null)" = "${TPM_UNLOCK_TEXT}" ]; then
        echo "=== INITRD TPM UNLOCK SETUP OK ==="
        echo verify > "${QEMU_MODE_FILE}"
    else
        echo "=== INITRD TPM UNLOCK SETUP FAIL ==="
    fi

    sleep 2
    reboot -f
}

verify_tpm_initrd_unlock() {
    echo "=== INITRD TPM UNLOCK VERIFY ==="
    TDATA=$(cat "${TPM_UNLOCK_FILE}" 2>&1)
    echo "INITRD TPM UNLOCK READ: [${TDATA}]"

    if [ "${TDATA}" = "${TPM_UNLOCK_TEXT}" ]; then
        echo "=== INITRD TPM UNLOCK OK ==="
    else
        echo "=== INITRD TPM UNLOCK FAIL ==="
        ls -la /z/c 2>&1 || true
    fi
}

verify_mount_fixtures() {
    local check_state_binds="${1:-1}"

    echo "=== INITRD MODULES/FIRMWARE MOUNT VERIFY ==="

    echo "=== INITRD FIRMWARE MOUNT SKIP ==="
    echo "=== INITRD MODULES MOUNT SKIP ==="

    RFDATA=$(cat /lib/firmware/test/fixture.txt 2>&1)
    echo "ROOTFS FIRMWARE FIXTURE READ: [${RFDATA}]"
    if [ "${RFDATA}" = "initos qemu firmware fixture" ]; then
        echo "=== INITRD ROOTFS FIRMWARE BIND OK ==="
    else
        echo "=== INITRD ROOTFS FIRMWARE BIND FAIL ==="
    fi

    RMDATA=$(cat "/lib/modules/$(uname -r)/kernel/fixture.txt" 2>&1)
    echo "ROOTFS MODULES FIXTURE READ: [${RMDATA}]"
    if [ "${RMDATA}" = "initos qemu modules fixture for $(uname -r)" ]; then
        echo "=== INITRD ROOTFS MODULES BIND OK ==="
    else
        echo "=== INITRD ROOTFS MODULES BIND FAIL ==="
    fi

    if [ "${check_state_binds}" = 0 ]; then
        echo "=== INITRD ROOTFS HOME BIND SKIP ==="
        echo "=== INITRD ROOTFS ROOT BIND SKIP ==="
        echo "=== INITRD ROOTFS NIX BIND SKIP ==="
        return
    fi

    HDATA=$(cat /home/root/bind-check.txt 2>&1)
    echo "ROOTFS HOME BIND READ: [${HDATA}]"
    if [ "${HDATA}" = "initos-qemu-root-bind-ok" ]; then
        echo "=== INITRD ROOTFS HOME BIND OK ==="
    else
        echo "=== INITRD ROOTFS HOME BIND FAIL ==="
    fi

    if [ -d /root ]; then
        RDATA=$(cat /root/bind-check.txt 2>&1)
        echo "ROOTFS ROOT BIND READ: [${RDATA}]"
        if [ "${RDATA}" = "initos-qemu-root-bind-ok" ]; then
            echo "=== INITRD ROOTFS ROOT BIND OK ==="
        else
            echo "=== INITRD ROOTFS ROOT BIND FAIL ==="
        fi
    else
        echo "=== INITRD ROOTFS ROOT BIND SKIP ==="
    fi

    NDATA=$(cat /nix/bind-check.txt 2>&1)
    echo "ROOTFS NIX BIND READ: [${NDATA}]"
    if [ "${NDATA}" = "initos-qemu-nix-bind-ok" ]; then
        echo "=== INITRD ROOTFS NIX BIND OK ==="
    else
        echo "=== INITRD ROOTFS NIX BIND FAIL ==="
    fi
}

run_tests() {
    echo "===== Hello World from initos! ====="
    echo "Kernel: $(uname -r)"
    echo "Init PID: $$"
    env
    set -x

    case "$(qemu_mode)" in
        verify)
        verify_tpm_initrd_unlock
        verify_mount_fixtures 1
            ;;
        stateless|direct)
            verify_mount_fixtures 0
            echo "=== INITRD STATELESS ROOT OK ==="
            echo "=== ALL TESTS COMPLETE ==="
            sleep 2
            reboot -f
            ;;
    esac

    echo "=== TPM2 TEST ==="

    mkdir -p /z/initos/tpm /z/tmp

    initos primary
    echo "primary exit=$?"
    echo "primary handle=0x81000000"

    initos seal "${TPM_TEST_KEY}"
    echo "seal exit=$?"
    echo "sealed handles dev=0x81001002 secure=0x81001003"

    echo "=== FSCRYPT ENV KEY TEST ==="
    FSCRYPT_DIR=/z/tmp/test_env_encrypted
    mkdir -p "${FSCRYPT_DIR}"

    FSCRYPT_KEY="my-user-password" initos fscrypt-setup "${FSCRYPT_DIR}"
    echo "fscrypt-setup (env) exit=$?"

    echo "env-secret-data" > "${FSCRYPT_DIR}/test.txt"
    echo "write exit=$?"
    sync
    EDATA=$(cat "${FSCRYPT_DIR}/test.txt" 2>&1)
    echo "FSCRYPT ENV READ: [${EDATA}]"

    if [ "${EDATA}" = "env-secret-data" ]; then
        echo "=== FSCRYPT ENV KEY OK ==="
    else
        echo "=== FSCRYPT ENV KEY FAIL (got: ${EDATA}) ==="
        ls -la "${FSCRYPT_DIR}/" 2>&1
    fi

    echo "=== FSCRYPT TPM TEST ==="
    FSCRYPT_DIR2=/z/tmp/test_tpm_encrypted
    mkdir -p "${FSCRYPT_DIR2}"

    FSCRYPT_KEY="${TPM_TEST_KEY}" initos fscrypt-setup "${FSCRYPT_DIR2}"
    echo "fscrypt-setup (tpm) exit=$?"

    echo "tpm-secret-data" > "${FSCRYPT_DIR2}/test.txt"
    sync
    TDATA=$(cat "${FSCRYPT_DIR2}/test.txt" 2>&1)
    echo "FSCRYPT TPM READ: [${TDATA}]"

    if [ "${TDATA}" = "tpm-secret-data" ]; then
        echo "=== FSCRYPT TPM OK ==="
    else
        echo "=== FSCRYPT TPM FAIL (got: ${TDATA}) ==="
        ls -la "${FSCRYPT_DIR2}/" 2>&1
    fi

    echo "=== ANTI-REPLAY TEST ==="
    initos lock_tpm
    echo "lock_tpm exit=$?"

    RESULT2=$(initos unseal 2>&1)
    rc=$?
    echo "second unseal exit=$rc"
    if [ $rc -ne 0 ]; then
        echo "=== ANTI-REPLAY OK (second unseal correctly rejected) ==="
    else
        echo "=== ANTI-REPLAY FAIL (second unseal should have failed) ==="
        echo "${RESULT2}"
    fi

    echo "=== ALL TESTS COMPLETE ==="

    sleep 2
    reboot -f
}

initos-init-base mount_sys

case "$(qemu_mode)" in
    setup)
        run_tpm_setup
        ;;
esac

if ! touch /z/.initos-qemu-state-check 2>/dev/null; then
    echo "ERROR: /z is not writable; STATE was not bind-mounted before switch_root"
    reboot -f
fi
rm -f /z/.initos-qemu-state-check

tag9p=/sys/bus/virtio/drivers/9pnet_virtio/virtio0/mount_tag
if [ -r "${tag9p}" ]; then
    echo "Using qemu 9p $(cat "${tag9p}")"
    mkdir -p /x
    if mount -t 9p -o trans=virtio,version=9p2000.L "$(cat "${tag9p}")" /x; then
        if [ -f /x/test.sh ]; then
            exec /x/test.sh
        fi
        echo "No /x/test.sh found; running built-in qemu tests"
    else
        echo "Failed to mount qemu 9p; running built-in qemu tests"
    fi
else
    echo "No qemu 9p mount tag found; running built-in qemu tests"
fi

run_tests
