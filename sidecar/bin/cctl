#!/bin/sh

# Container control: Script to run a container with opinionated volumes and layout.
#
# This may execute podman, docker - or bubblewrap, unshare (and eventually VMs with
# qemu, cloud-hypervisor, etc). 
# 
# Regardless of implementation tools, it expects:
#
# - a command as first param (start, run, sh, etc) - $CMD
# - a container name as second param (example-deb) - $NAME - not needed if RC_SVCNAME is set.
#
# Environment on host:
# - ${HOME}/.cache/c/${NAME} - base dir, 
# - ${HOME}/.cache/c/${NAME}/share - shared with the container as /z, 
# - ${HOME}/.cache/c/${NAME}/.env - environment
# - ${HOME}/.cache/c/${NAME}/mnt/ro - read only base, may be a symlink
# - ${HOME}/.cache/c/${NAME}/rootfs - optional overlay mounted dir, may be a symlink
# 
# Environment in container/VM/pod:
# - /z - shared with the host - may be virtio, bind mount for container, 9p for remote
#    - data - shared with the host, read write
#    - home/build - the main user.
# 
# Why: 
# - too hard to remember the CLI of each tool, all are different for some reason.
# - too much flexibility and power - and complexity as result
# - for remote - ssh, kubectl or other tools can be used - also too many/complex/different.
# 
# 
#
# Similar to podman toolbox - but no home access.
# toolbox [create, enter = shell, ]
# 
TAG=${TAG:-latest}
REPO=${REPO:-ghcr.io/costinm/initos}


# TODO: add ujail, chroot, lxc options

# Can be started with:
# RC_SVCNAME=NAME supervise-daemon NAME --start /x/opt/virt/vrun -- start

# If not specified - default to the dev container. No UI.
NAME=${POD:-initos_dev}

if [ -n "${RC_SVCNAME}" ]; then
  # If running as a service (alpine init), set the pod name to the service name.
  NAME=${RC_SVCNAME}
fi

# Alternative: unshare -U -r --pid --fork --mount-proc --mount --uts --ipc --cgroup --propagation shared

# Note that '--pid' and '--fork' go together, and will run the command as process 1.
# Without --mount-proc - because of 'shared' the original proc is mounted - mount -t proc proc /proc to see the mapped processes.
# PID 1 is only needed for testing init.
#
# -U -r -> user namespace, user mapped to root
# --mount -> separate mount namespace, user can mount stuff
# --uts -> can set hostname


DOCKER=podman
# Run as the same user ID that is calling podman
#export PODMAN_USERNS=keep-id

# podman unshare 
# podman unshare --rootless-netns
# podman system migrate
#
# setpriv --reuid 1000 --regid 1000 --clear-groups /bin/bash

# The opinionated part of the script: layout on host and guest. Fixed volumes,
# the script shouldn't allow arbitrary mounts.
_mounts() {
  # Ephemeral, can be recreated - mounted as /build
  OUT_DIR="${OUT_DIR:-$(pwd)/target/c/${NAME}}"
  mkdir -p "${OUT_DIR}" 

  if [ -n "${DATA}" ]; then
      VOLS="${VOLS} -v ${DATA}:/data"
  fi
  VOLS="${VOLS} -v ${OUT_DIR}:/build -e out=/build"

  # Use current directory - so debug paths match.
  VOLS="${VOLS} -v $(pwd):$(pwd) -e src=$(pwd) -w $(pwd)"

  if [ -n "${SECRETS}" ]; then
      #${HOME}/.ssh/secrets/${NAME}
      mkdir -p ${SECRETS}
      VOLS="${VOLS} -v ${SECRETS}:/var/run/secrets"
  fi
}


# Start a container based on IMG that stays around.
# Use exec to run commands.
start() {
    local IMG=${1:-debian:trixie-slim}

    _mounts
    ${DOCKER} run -d \
      ${CARGS} ${VOLS} \
      --name $NAME \
      ${IMG} sleep infinity || ${DOCKER} start "$NAME"
}

_start_bwrap() {
  SANDBOX_HOME=${HOME}/.local/virt/${NAME}

  mkdir -p /tmp/vm/${NAME} ${SANDBOX_HOME}

  #slirp4netns --detach --netns-type=path /tmp/virt/${NAME}/agent-netns tap0
  # And --netns ... param in bwrap
  # Uses 10.0.2.100, requires 'ip link set up' in container, -P 8080:80 to forward

  #pasta --config-net --netns /tmp/agent-netns & 
  # -t PORT, -u PORT.
  # passt package.

  pasta --config-net \
  bwrap \
    --unshare-all \
    --share-net \
    --hostname "agent-sandbox" \
    --netns /tmp/virt/${NAME}/agent-netns \
    --proc /proc \
    --dev /dev \
    --tmpfs /tmp \
    --tmpfs /run \
    --dir "$SANDBOX_HOME" \
    --setenv HOME "$SANDBOX_HOME" \
    --ro-bind /usr /usr \
    --ro-bind /bin /bin \
    --ro-bind /lib /lib \
    --ro-bind /lib64 /lib64 \
    --ro-bind /etc/resolv.conf /etc/resolv.conf \
    --ro-bind /etc/ssl /etc/ssl \
    --bind "$PROJECT_DIR" "$PROJECT_DIR" \
    --chdir "$PROJECT_DIR" \
    --die-with-parent \
  /usr/bin/tmux new-session -s agent-control
}

_tmux_attach() {
  # Find the PID of the bwrap process
  AGENT_PID=$(pgrep -f "agent-sandbox")
  # Enter the namespace to attach
  sudo nsenter -t $AGENT_PID -m -u -i -n -p tmux attach -t agent-control
}

_start_x11() {
  bwrap ... \
  --setenv DISPLAY :99 \
  /usr/bin/bash -c "Xvfb :99 -screen 0 1280x1024x24 & your-agent-command"
}

stop() {
  ${DOCKER} rm -f ${NAME}
}


sh() {
    ${DOCKER} exec -it ${NAME} "$@"
}

enter() {
    ${DOCKER} exec -it ${NAME} bash "$@"
}

_bwrap() {
  bwrap \
  --ro-bind /usr /usr \
  --ro-bind /bin /bin \
  --ro-bind /lib /lib \
  --ro-bind /lib64 /lib64 \
  --bind "$PWD" "$PWD" \
  --tmpfs /tmp \
  --unshare-all \
  --hostname $NAME \
  --die-with-parent \
  /usr/bin/bash -c "$@"
}



x11container() {
    DOCKER_HOST=$(ip -4 addr show docker0 | grep -Po 'inet \K[\d.]+')
    #echo HOST $DOCKER_HOST

    #xhost +local:

   VOL="-v /tmp/.X11-unix:/tmp/.X11-unix \
    -v ${HOME}:${HOME} \
   -v /dev/shm:/dev/shm \
   -v /var/run/dbus/system_bus_socket:/var/run/dbus/system_bus_socket \
   -v /var/lib/dbus/machine-id:/var/lib/dbus/machine-id \
   -v $HOME/.config/pulse/cookie:/tmp/pulse/cookie"

   ENV="--device /dev/dri/card0 -e DISPLAY=:0 \
       -e HOME=${HOME}
       -e PULSE_SERVER=tcp:$DOCKER_HOST:4713 \
       -e PULSE_COOKIE=/tmp/pulse/cookie"
       
    echo $VOL $ENV
}


### CHROOT BASED (full access to host)

# Setup a chroot env
start_chroot() {

  R=${1:-${WORK}}
  if [ "$POD" = "/sysroot" ]; then
    R=/sysroot
  fi

  # https://wiki.gentoo.org/wiki/Chroot/en
  mount --rbind /dev ${R}/dev
  mount --make-rslave ${R}/dev
  mount -t proc /proc ${R}/proc
  mount --rbind /sys ${R}/sys
  mount --make-rslave ${R}/sys
  mount --rbind /tmp ${R}/tmp

  mount -o bind /lib/modules ${R}/lib/modules
  mount -o bind /lib/firmware ${R}/lib/firmware

  #mount -o bind /ws/initos ${R}/ws/initos
  #mount -o bind /x/vol/devvm-1/initos ${R}/x/initos/
  #mount -o bind /x/vol/devvm-1/initos/boot ${R}/boot
}

run_chroot() {
  R=${WORK}
  if [ "$POD" = "/sysroot" ]; then
    R=/sysroot
  fi

 chroot ${R} "$@"
}

run_unshare() {
 # No --net
 unshare --root=${WORK} --pid --mount --fork --mount-proc \
     --uts --ipc --cgroup --propagation shared  -- "$@"
}

stop_chroot() {
  X=${WORK:-/sysroot}

  umount ${X}/dev/pts
  umount  ${X}/dev/
  umount  ${X}/proc/
  umount  ${X}/tmp/
  umount  ${X}/sys/
}
#   ctr run -t --cni --rootfs ./rootfs/ devvm /bin/bash
#   ctr c delete devvm

# Default - run it as a chroot (arch-chroot handles that well)
sidecar() {
  # Using chroot to run a different image, not to isolate.
  mount -o bind /x /initos/sidecar/x
  mount -o bind / /initos/sidecar/sysroot
  
  # The arch script takes care of sys, etc.
  /initos/sidecar/usr/bin/arch-chroot \
    /initos/sidecar /sbin/initos init_sidecar &

  # alternative: docker/podman/direct crun to keep it in a 
  # priv container. 
}

priv() {
  docker pull ${REPO}/initos-sidecar:${TAG}
  docker run --name initos-sidecar \
    --rm -it \
    --network host \
    --cap-add=ALL \
    --privileged \
    --security-opt seccomp=unconfined \
    --device /dev/fuse \
    --device /dev/kvm \
    --device /dev/dri \
    --device /dev/tty0 \
    -v /x:/x \
    -v /:/rootfs \
    ${REPO}/initos-sidecar:${TAG} tini sleep infinity 

    #-v /tmp/.X11-unix:/tmp/.X11-unix:rw \
    #-v /run/user/1000/podman/podman.sock:/run/user/1000/podman/podman.sock

}

setup() {
   #docker network create -d ipvlan --subnet 192.168.0.0/17 --gateway 192.168.1.254 --ip-range 192.168.7.0/24 -o parent=br-lan ipvl
   #docker network create --ipv6 --driver=bridge -o 'com.docker.network.bridge.name=br-lan' br-lan
   docker network create  -d macvlan -o parent br-lan --subnet 192.168.0.0/17 --gateway 192.168.1.254 
}

CMD=$1
[ $# -gt 0 ] && shift

case $CMD in
start) start "$@" ;;
stop) stop "$@" ;;
cmd) shift; "$@" ;;
*)
  if [ -z "${CMD}" ]; then
    enter
  else
    sh "${CMD}" "$@"
  fi ;;
esac
