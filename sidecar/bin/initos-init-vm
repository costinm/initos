#!/bin/sh

if [ "${initos_dbg}" = 1 ]; then
  set -x
fi

mount_disks() {
  if [ -n "${initos_data}" ]; then 
    mount ${initos_data} /x || true
  fi

  if [ -n "${initos_cache}" ]; then 
    mount ${initos_cache} /x/@cache || true
  fi

  # TODO: For a VM, can use a separate swap disk (if we find a way to identify it...)
  # Like VMs, cache may be on a separate unencrypted disk - it is not supposed to hold secrets. 
  if [ -f /x/@cache/swap ]; then
    swapon /x/@cache/swap
  fi

  # Rootfs can be on virtiofs or /dev/vda
  if [ -n "${initos_root}" ]; then
      #mount -t btrfs -o nobarrier /dev/vda /sysroot
      # We may use custom label for EXT4
      mount ${initos_root} /sysroot
  fi

  local tag9p=/sys/bus/virtio/drivers/9pnet_virtio/virtio0/mount_tag
  if [ -f ${tag9p} ]; then
    mkdir -p /src
    mount -t 9p -o trans=virtio,version=9p2000.L $(cat ${tag9p}) /src
  fi

}

# Main function after mounting proc and dealing with busybox.
# For VMs with custom kernel, virtiofs is compiled in along with
# all required drviers - and virtofs is already mounted as root.
# 
# Init network and:
# - execute /initos/init if present (no pivot)
# - pivot to /dev/vda as rootfs
initramfs_init_vm() {
  net_cfg
  mount_disks

  # Simplest case: run a startup script directly, using virtiofs 
  # as root.
  if [ -f /initos/initos-pod ]; then
    exec /initos/initos-pod start
  fi 


  # mount -o bind / /z # The shared dir will be /z by pivot
  

  if [ -f /sysroot/sbin/init-pod ]; then
      move_mounted_to_sysroot
      pivot_root /sysroot /z
      exec /sbin/init-pod start
  elif [ -f /sysroot/usr/bin/systemd ]; then
    move_mounted_to_sysroot
    pivot_root /sysroot /z
    exec /usr/bin/systemd --system 
    #--log-level=err  --system \
    #    --default-standard-output=tty --default-standard-error=tty
    # --unit=rescule.target
  else
    exec /bin/sh
  fi 
}

## First step - expand busybox and mount the basic filesystems.
# Extracted from alpine init.
initramfs_1st() {
  /bin/busybox mkdir -p \
    /sbin /usr/bin \
    /usr/sbin \
    /dev \
    /media/cdrom \
    /media/usb \
    /tmp \
    /etc \
    /dev/shm \
    /run /proc /sys \
    /sysroot /x /z /boot/efi /lib/modules \
    /lib/firmware /var/cache /var/log /home /initos

  /bin/busybox --install -s

  [ -c /dev/null ] || mknod -m 666 /dev/null c 1 3

  if [ -e /proc/cmdline ]; then
    return
  fi

  mount -t sysfs -o noexec,nosuid,nodev sysfs /sys

  mount -t devtmpfs -o exec,nosuid,mode=0755,size=2M devtmpfs /dev 2>/dev/null \
    || mount -t tmpfs -o exec,nosuid,mode=0755,size=2M tmpfs /dev && mdev -f -s

  [ -c /dev/kmsg ] || mknod -m 660 /dev/kmsg c 1 11u

  mount -t proc -o noexec,nosuid,nodev proc /proc
  [ -c /dev/ptmx ] || mknod -m 666 /dev/ptmx c 5 uub
  [ -d /dev/pts ] || mkdir -m 755 /dev/pts

  mount -t devpts -o gid=5,mode=0620,noexec,nosuid devpts /dev/pts  
  mount -t tmpfs tmpfs /run
}


move_mounted_to_sysroot() {
  cat /proc/mounts 2>/dev/null | while read DEV DIR TYPE OPTS ; do
    if [ "$DIR" != "/" -a "$DIR" != "/sysroot" -a -d "$DIR" ]; then
      mkdir -p /sysroot$DIR
      mount -o move $DIR /sysroot$DIR
    fi
  done

  sync
}

net_cfg() {
  ip link set dev lo up

  # Use IPAM or static config - no DHCP in VMs please!

  if [ -n "$ipv6_addr" ] ; then
    ip link add name br-lan type bridge
    ip link set dev br-lan up

    ip link set dev eth0 master br-lan
    ip link set dev eth0 up

    ip addr add ${ipv4_addr}/22 dev br-lan

    ip -6 addr add ${ipv6_addr}/64 dev br-lan
    ip -6 route add default via ${ipv6_gw} dev br-lan

  elif [ -n "$br_addr" ] ; then
  
    ip link add name br-lan type bridge
    ip link set dev br-lan up

    ip link set dev eth0 master br-lan
    ip link set dev eth0 up

    ip addr add ${br_addr}/17 dev br-lan

  elif [ -n "initos_ip" ] ; then
  
    ip link set dev eth0 up

    ip addr add ${initos_ip} dev eth0
  fi

  route add default gw ${initos_gw}
  hostname $initos_host
}

# This script is run as root, with $USER set to the name of the user to 
# be created.
# 
# There are few types of users:
# - admin - equivalent to root, with sudo, etc. 
# - shell - normal user, typically custom name - with desktop/X access
#    and user credentials, secrets, etc.
# - build (or build)- developer, minimal credentials, may have remote desktop
#   access for IDEs. 
# - app-XXX - application specific user, to keep apps isolated.
user_add() {
    local user=$1

    mkdir -p /var/cache/user/$user
    chown $user /var/cache/user/$user

    # May work if /var/cache/user is 1777
    mkdir -p /var/cache/user/$user || true

    mkdir -p /var/cache/user/$user/.cache \
       /var/cache/user/$user/go
       /var/cache/user/$user/.venv \

       
    # As user:
    rm -rf /home/$user/.cache /home/$user/go
    ln -s /var/cache/user/$user/.cache /home/$user/.cache
    ln -s /var/cache/user/$user/go /home/$user/go
}

prepare_x() {
  if [ -f /etc/init.d/dbus ]; then
    /etc/init.d/dbus start
  fi
  if [ -f /etc/init.d/x11-common ]; then
    /etc/init.d/x11-common start
  fi

  rm -f /tmp/.X*-lock /tmp/.X11-unix/X${DISPLAY} || true
}

# Add a custom user - with PID, PGID, PUSERNAME ('pod').
# Should be 'build' on dev containers, 'user' or real user on regular
# machines (where user may use chrome - but not dev)
add_main_user() {
  local u=${USERNAME:-build}
  local h=${HOME:-/home/${u}}
  local USERID=${USERID:-1000}
  userdel ${u} || true

  echo Adding $u with $h and $USERID

  useradd -u ${USERID} -g users -G users -s /bin/bash \
         -d ${h} ${USERNAME}

  # Set encrypted password (to invalid). Only ssh login
  # or VNC
  usermod -p '*' ${USERNAME}

  #chown ${u} /home /work

  # rm -rf /work && ln -s /x/work /work

  usermod -a -G chrome-remote-desktop ${u} || true
  usermod -a -G docker ${u} || true
  usermod -a -G kvm ${u} || true
  usermod -a -G video ${u} || true
  usermod -a -G render ${u} || true

  # access to /etc/ssl/private
  usermod -a -G ssl-certs ${u} || true

  echo "${u} ALL=NOPASSWD: ALL" >> /etc/sudoers

  chmod 4755 /x/sync/app/chrome/chrome-sandbox || true
}


if [ "$$" = "1" ]; then
  initramfs_1st
  echo "INITOS-VM: $@" > /dev/kmsg

  initramfs_init_vm
else
  "$@"
fi
