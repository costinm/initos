#!/opt/busybox/bin/sh

# verified boot sequence using TPM/2 - requires secure boot enabled and only our
# key installed.
#
# If secure boot is not enabled or generic distro keys are present: an attacker
# can boot a different kernel/image and unlock using TPM key.

export PATH=/opt/initos/bin:/opt/busybox/bin:/bin:/sbin:/usr/bin:/usr/sbin
export TPM_DIR=/z/initos/tpm
set -x

initos-init mount_sys
initos-init init_ext4_data_dir # STATE mounted to /z
#initos-init mount_modules


if [ -f ${TPM_DIR}/tpm_handle ]; then
  #initos-init load_drivers
  initos-init unlock_c_tpm
else
  # For machines without TPM, password required at boot.
  initos-init unlock_home
fi
# /z/c unlocked - encrypted dir.

initos-init mount_modules

# the rootfs is either an erofs image, with overlay under /z/c 
# or a RW directory under /z/c - it is roughtly equivalent.
# 
# Using only a RO image without overlay is slightly better as security
# but harder to use.
initos-init init_rootfs

exec initos-init end_init


