  local d=${1}

  sfdisk --part-label $d 101 UBOOTA
  sfdisk --part-label $d 102 UBOOTB
  sfdisk --part-label $d 1 USTATE

  mkfs.ext4 -L USTATE -O encrypt,verity ${d}1
  # mkfs.vfat -n UBOOTA ${d}101
  # mkfs.vfat -n UBOOTB ${d}102

  # use e2label or fatlabel to change
}

