#!/opt/busybox/bin/sh

# Helpers for setup and operating the host.

### Install ###

disk_setup() {
  DISK=${1:-"/dev/sdb"}
  suffix=""
  if echo "$DISK" | grep -q "nvme"; then
    suffix="p"
  fi
  if echo "$DISK" | grep -q "mmcblk"; then
    suffix="p"
  fi


  sfdisk --label gpt "$DISK" <<EOF
label-id: gpt

partition-100 : size=64M, name="BOOTD", type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B
partition-101 : size=64M, name="BOOT1", type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B
partition-102 : size=64M, name="BOOT2", type=C12A7328-F81F-11D2-BA4B-00A0C93EC93B
partition-1   : size=+, name="STATE"
EOF
}

setup_fs() {
  DISK=${1:-/dev/sdb}

  mkfs.ext4 -L STATE -O encrypt,verity ${d}1
  mkfs.vfat -n BOOT1 ${DISK}101
  mkfs.vfat -n BOOT2 ${DISK}102

  mkfs.ext4 -L INITOS1 ${d}111
  mkfs.ext4 -L INITOS2 ${d}112

}

upgrade() {
  DISK=${1:-/dev/sdb}
  PART=${2:-101}
  dd if=/z/img/${PART}/initos-signed.fat of=/dev/${DISK}${PART}
  #sync
  #/opt/busybox/bin/reboot -f

}

mount_install() {
  mkdir -p /mnt/STATE /mnt/BOOT1 /mnt/BOOT2 
  mount LABEL=STATE /mnt/STATE
}

part_labels() {
  local d=${1}

  sfdisk --part-label $d 100 BOOTD
  sfdisk --part-label $d 101 BOOT1
  sfdisk --part-label $d 102 BOOT2
  sfdisk --part-label $d 1 STATE

  mkfs.ext4 -L STATE -O encrypt,verity ${d}1
  #mkfs.vfat -n BOOTA ${d}101
  #mkfs.vfat -n BOOTB ${d}102

  # use e2label or fatlabel to change
}

