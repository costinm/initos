#!/opt/busybox/bin/sh

# This is intended for 'userdebug' mode/testing - when the
# rootfs and boot sequence is not verified.
#
# The EFI boot should be configured to load ext4 
# as rw, by PARTLABEL.
#
# There is no pivot_root in this mode - or expectation
# of protection against 'evil maid' and physical access,
# which is the case for almost all linux distros.
#
# Besides a normal distro, the ext4 disk should also 
# include a '/z' directory: 
#   - a/initos - the initos package, unpacked.
#   - a/ - other mounted images.
#   - img - with firmware, modules, other erofs images
#   - initos - overlay mnt, tpm keys, etc
#   - c - encrypted data
set -x
export PATH=/opt/initos/bin:/opt/busybox/bin:/bin:/sbin:/usr/bin:/usr/sbin

# Mount system (proc,sys,dev,etc) and tmp fs
initos-init mount_sys

if [ -n "${INITOS_INITRD}" ]; then
  echo "INITRD debug MODE - exec sh, use 'exec /opt/initos/bin/initos' to continue"
  exec sh
fi

echo
echo "Press 'd' to enter debug shell in 3 seconds"
echo
read -n 1 -t 3 debugkey

echo "- mounting STATE"
# Mount STATE disk - make sure ecryptfs is enabled
initos-init init_ext4_data_dir

echo "- mounting modules/firmware"
# From STATE, mount firmware and modules
initos-init mount_modules

if [ ! -d /z/c ] ; then
  echo "Encrypted STATE disk doesn't exist - initializing it"

  mkdir /z/c
  
  FSCRYPT_KEY=$(cat /dev/urandom | tr -dc a-zA-Z0-9 | head -c14)

  echo "Enter host unlock password:"
	read -s -r KEY 2>/dev/null 
  echo -n ${FSCRYPT_KEY} | KEY=${KEY} initos encrypt > /z/initos/c.age

  FSCRYPT_KEY=${FSCRYPT_KEY} initos fscrypt-setup /z/c

  echo "Initial setup done - debug shell (exit when done):"
  sh

  mkdir -p /z/c/home/root
  mkdir -p /z/c/mnt
  
  # Using initial values from the USB installer
  #cp -a /z/home/* /z/c/home/
  #cp -a /z/initos/etc /z/c/
  
else
  # if [ "${debugkey}" = "d" ]; then
  #   echo "Before unlock /c"
  #   sh 
  # fi
  # From STATE, mount the system encrypted disk (/c).
  # 
  initos-init unlock_home
fi


if [ "${debugkey}" = "d" ]; then
  echo "Before rootfs pivot"
  sh 
fi
# Find and pivot to the real rootfs, using files from the encrypted dir
# and/or (verity) images. 
initos-init init_rootfs

if [ "${debugkey}" = "d" ]; then
  echo "After pivot - root is the target disk"
  sh 
fi

# On dev machines - load the images RW, no verification anyways
mkdir -p /mnt/INITOSA /mnt/INITOSB /mnt/BOOTA /mnt/BOOTB
mount LABEL=INITOSB /mnt/INITOSB
mount LABEL=INITOSA /mnt/INITOSA
mount LABEL=BOOTA /mnt/BOOTA
mount LABEL=BOOTB /mnt/BOOTB
(cd /mnt/INITOSA && mount -o remount -rw .)
(cd /mnt/INITOSB && mount -o remount -rw .)

if [ "${debugkey}" = "d" ]; then
  echo "Before starting init or systemd"
  sh
fi

exec initos-init end_init




