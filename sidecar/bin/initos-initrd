#!/opt/busybox/bin/sh

# Initrd fallback/recovery/install path.
# Called by initrd ONLY in 'unlocked bootloader' mode, when EFI 'secure boot' is off
# in special cases:
# - can't find STATE (or USTATE) partition
# - can't find one of the required volumes (modules, firmware, rootfs - initos.erofs)
# - verification fails
# - can't unlock /z/c using TPM2 or password
# - the STATE disk is not initialized - no /c, /img, /initos dirs
#   
#
# the initrd will switch_root instead of pivot_root.
set -x
export PATH=/opt/initos/bin:/opt/busybox/bin:/bin:/sbin:/usr/bin:/usr/sbin

echo "Recovery shell: after exit, it will switch_root to /sysroot"
if [ -n "${INITOS_BOOT_ERROR}" ]; then
  echo "Boot fallback reason: ${INITOS_BOOT_ERROR}"
fi

sh 

# Find and switch_root to the real rootfs, using files from the encrypted dir
# and/or (verity) images.
exec initos-init init_rootfs_switch
