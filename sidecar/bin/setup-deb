  #   ms-toolsai.jupyter
 
  # Enabled using systemd: 
  #systemctl enable --now code-server@$USER.service

  # TODO: maybe install zed too?
  #curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
}


"$@"
