#!/bin/sh

# Build script for adding debian packages in a container to use
# as 'read only' or 'distroless'.
#
# - no 'apt' or package operations after the image is built
#   read-only and signed.
# - kernel/modules/boot loader are separate, not included in the rootfs.
#
# Main target are 2 variants for 'dev' and 'host'. 
#
# The dev image should be able to build kernel and run in a container.
# 'devui' will also include KasmVnc, code, chrome and other UI tools for devel.
# 
# The hostui image will not include dev tools - but adds host-management tools
# (efibootmgr, etc) and labwc.
# 
 

set -x
set -e

export DEBIAN_FRONTEND=noninteractive
APTINSTALL='apt install -o Dpkg::Options::=--force-confold --assume-yes --no-install-recommends '

out=${out:-/build}
src=${src:-/ws}

# Will make sure the user exists - useful in pods for
# running as a custom username.
USERNAME=${USERNAME:-build}

clean() {
  apt clean

  rm -f /etc/ssh/ssh_host_*_key* || true
  rm -f /etc/machine-id || true
}

# Host tools, Wayland ui.
hostui() {
  base
  
  deb_host
  add_host_ui
}

# Developer tools - CLI only
initos_dev() {
  base
  add_dev_tools
}

# Developer tools, Kasm(or X) remote, code-server.
initos_devui() {
  initos_dev
  ui
  # No local UI - but editor and remote access, plugins
  add_code
}

######## Components 
base() {
  apt update
  add_base_users

  # Networking, shared tools - both host and container/vm.
  tools

  # locales should be regenereted - dpkg-reconfigure locales
  # or /etc/locale.gen and run locale-gen
  sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen

  locale-gen

}

# Add a set of core users. Using Android ID for system, separate users for each app
# and separate user profiles. User 1 is the main user - unlocked by a separate key from
# the TPM/boot key.
add_base_users() {
  local u=system
  local h=/home/system

  mkdir -p /home

  if id -u 1000 >/dev/null 2>&1; then
    return 0
  fi

  groupadd -g 1000 system || true
  groupadd -g 2000 restic || true

  useradd -u 1000 -g system -G users,restic -s /bin/bash \
         -d /home/system system || true

  # p sets encrypted pass - * is not a valid one, so pass login disabled.
  usermod -p '*' system || true

  useradd -u 2000 -g restic -G restic -s /bin/bash \
         -d /home/backup restic || true
  usermod -p '*' restic || true

  chown system /home/system
  echo "system ALL=NOPASSWD: ALL" >> /etc/sudoers

  # this maps to user 10000 in a userspace pod created by system 
  # with 100.000 mapped to user 0.
  groupadd -g 109999 build || true
  useradd -u 109999 -g build -s /bin/bash -d /home/build build || true

}

## Install sets of packages for different features.

# Common networking tools - no hardware specific (wifi on host only)
add_network() {
  # Network tools
  $APTINSTALL iproute2 iputils-ping net-tools \
    dnsutils ifupdown ifupdown-extra bridge-utils \
    tcpdump iptables nftables iperf3 radvdump \
    curl wget net-tools openssh-client

  if [ "${INSTALL_SSHD:-}" = "1" ]; then
    $APTINSTALL openssh-server

    # Avoid distributing generated host keys in image artifacts.
    rm /etc/ssh/ssh_host_* || true
  fi
}

# Common tools and networking for a host.
tools() {
  $APTINSTALL ca-certificates curl gpg \
     tini  bsdutils  file findutils fuse3 lsof fuse-overlayfs 

  $APTINSTALL gpg \
      vim mc tmux \
      git less bash-completion \
      rsync bsdutils findutils unzip \
      locales kmod

  add_network

  $APTINSTALL nix-bin
  mkdir -p /etc/nix
  echo "experimental-features = nix-command flakes" > /etc/nix/nix.conf
  echo "build-users-group =" >> /etc/nix/nix.conf

  # Include basic container ability - both host and dev
  # toolbox adds flatpak too
  $APTINSTALL podman passt
  $APTINSTALL podman-docker
  $APTINSTALL podman-compose

  # downloads a 500M image similar to dev, cctl.
  # Useful to compare.
  # $APTINSTALL podman-toolbox

  # Used in flatpak - mainly for host. 
  # Useful to comnpare with nix, mainly for isolated UI apps.
  # $APTINSTALL ostree

  $APTINSTALL bubblewrap 
  
  # May be better installed as nix or opt/ packages instead of deb packages.
  #$APTINSTALL restic rclone
  # kmod needed for modprobe, etc

  # Note that ssh won't start now - keys need to be regenerated on install.

  echo N | $APTINSTALL sudo
}

