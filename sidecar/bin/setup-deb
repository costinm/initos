# Download the binaries required for running VMs.
# 
# Currently using cloud-hypervisor and virtiofsd.
virt_install() {
  local d=${DEST:-/opt/virt}
  mkdir -p "$d"

  # Dynamically retrieve the latest release tag of cloud-hypervisor
  local latest
  latest=$(curl -sL --connect-timeout 10 https://api.github.com/repos/cloud-hypervisor/cloud-hypervisor/releases/latest | grep '"tag_name":' | sed -E 's/.*"tag_name":\s*"([^"]+)".*/\1/' || true)
  if [ -z "$latest" ]; then
    # Fallback to redirect URL parsing
    local redirect_url
    redirect_url=$(curl -Ls --connect-timeout 10 -o /dev/null -w "%{url_effective}" https://github.com/cloud-hypervisor/cloud-hypervisor/releases/latest || true)
    latest=${redirect_url##*/}
  fi
  if [ -z "$latest" ] || [ "$latest" = "latest" ]; then
    # Fallback to hardcoded safe default if both network calls/parsers fail
    latest="v44.0"
  fi
  echo "Installing cloud-hypervisor ${latest}..."

  # Download cloud-hypervisor binaries with retry logic and error checking
  curl -f -L --retry 3 --retry-delay 2 --connect-timeout 15 \
    "https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/${latest}/ch-remote" \
    -o "${d}/ch-remote"
  chmod +x "${d}/ch-remote"

  curl -f -L --retry 3 --retry-delay 2 --connect-timeout 15 \
    "https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/${latest}/cloud-hypervisor-static" \
    -o "${d}/cloud-hypervisor"
  chmod +x "${d}/cloud-hypervisor"

  # Download and extract virtiofsd
  echo "Installing virtiofsd..."
  curl -f -L --retry 3 --retry-delay 2 --connect-timeout 15 \
    "https://gitlab.com/virtio-fs/virtiofsd/-/jobs/artifacts/main/download?job=publish" \
    -o /tmp/virtiofsd.zip
  
  unzip -q -o /tmp/virtiofsd.zip -d /tmp
  if [ -f /tmp/target/x86_64-unknown-linux-musl/release/virtiofsd ]; then
    mv /tmp/target/x86_64-unknown-linux-musl/release/virtiofsd "${d}/virtiofsd"
  else
    echo "Error: virtiofsd binary not found in zip" >&2
    exit 1
  fi
  rm -rf /tmp/target /tmp/virtiofsd.zip

  #cp /usr/bin/ch-remote ${d}/ch-remote.musl
  # Sidecar should be built after the initrd files are generated.
  # The lib/modules are in the debian file.
  # cp /data/virt/* /opt/virt/
}

add_host_ui() {
  # Includes x11-common but not xorg
  $APTINSTALL  \
           libdbus-glib-1-2 \
           rofi alttab d-feet  \
          libinput-tools keyd  kbd \
          libnotify-bin fonts-font-awesome 


  add_chrome

  # I don't think flatpak is the right approach, too tied to systemd and FHS,
  # home exposed and too many gaps compared to containers.
  # waysecure + mounting the sockets to a container is much safer, if apps required the
  # portals - better to not use them at all. 
  # $APTINSTALL flatpak
  # flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo

  #echo "exec /etc/X11/Xsession /usr/bin/i3" > /etc/chrome-remote-desktop-session

  #brighnessctl
  # waylock \
  # bemenu grim slurp
  # dunst is alternative to mako-notifier - both use dbus org.freedesktop.Notifications
  # libnotify-bin include notify-send

  # Required for Zed and other GPU apps.
  #sudo apt install vulkan-tools libvulkan1 libvulkan-dev
  #sudo apt install mesa-vulkan-drivers
  #vulkaninfo # returns a long text block of info

  # wlopm - power management

  # Zed
  # curl -f https://zed.dev/install.sh | sh

  # wofi - like d-menu.
  # waybar - notifications, status bar on top.
  # swayilde, swaylock - lock screen
  # dunst (or mako) - notifications.
  # wlopm - power management for wayland screen.
  # rofi: menus (launch, windows)

  # Wayland

  $APTINSTALL  \
            labwc foot wofi brightnessctl swaylock \
            swayidle dunst wlopm waybar  wayland-utils \
            wlr-randr  wdisplays

  # TODO: build https://git.sr.ht/~whynothugo/way-secure 
  
  # audio, video
  $APTINSTALL  bluez blueman pipewire pipewire-pulse wireplumber \
        libspa-0.2-bluetooth \
        xdg-desktop-portal xdg-desktop-portal-wlr \
        dbus-x11 rtkit bluez 

  # For code:
  # 12M gtk
  $APTINSTALL libnss3 libatk1.0-0 libatk-bridge2.0-0

  #echo "exec /etc/X11/Xsession /usr/bin/i3" > /etc/chrome-remote-desktop-session
  video_perms
}

video_perms() {
 usermod -aG input system
 usermod -aG video system

}

build_way_secure() {
    local repo="https://git.sr.ht/~whynothugo/way-secure"
    local tmp_dir=$(mktemp -d)
    git clone "$repo" "$tmp_dir"
    cd "$tmp_dir"
    cargo build --release --target "${MUSL_TARGET}"
    
    local bin_name="way-secure"
    local bin_path="target/${MUSL_TARGET}/release/${bin_name}"
    
    if [ -f "$bin_path" ]; then
        strip "$bin_path"
        mkdir -p "${src}/prebuilt/bin"
        cp "$bin_path" "${src}/prebuilt/bin/${bin_name}"
        echo "  Copied: ${src}/prebuilt/bin/${bin_name}"
    else
        echo "  Error: Binary $bin_path not found"
        exit 1
    fi

    cd - > /dev/null
    rm -rf "$tmp_dir"
}

