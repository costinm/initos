# On dev machine only, not on hosts.
add_kasm() {
  KASM_VER=${KASM_VER:-1.4.0}
  local DIST=${1:-trixie}
  #local DIST=${1:-bookworm}

  # 220M
  curl -fsSL -o /tmp/kasmvnc.deb \
    https://github.com/kasmtech/KasmVNC/releases/download/v${KASM_VER}/kasmvncserver_${DIST}_${KASM_VER}_amd64.deb

  $APTINSTALL /tmp/kasmvnc.deb
  $APTINSTALL libdatetime-perl
  rm /tmp/kasmvnc.deb

}

# UI for VM or container - not using dri, remote.
# Any VNC would work - Kasm works better in browser IMHO.
ui() {
  #apt update
  # d-feet - dbus inspector

  # i3 instslls i3-wm, dunst, i3lock, i3status suckless-tools

  # x11vnc
  # xsettingsd

  # xfce4-polkit - display auth dialog
  # kitty - too heavy

  # i3 based UI.
  # Alternatives: openbox, sway

  # last release: 2010: openbox
  # fluxbox is similar - 2015 last release

  # obconf: +65M
  # obkey - key config

  # i3 +10M

  # eterm: 1.3M, but can't find font
  # xfce4-terminal: +74M
  # kitty: 16M


  # This adds fonts and a lot of stuff - let's add sway and labwc too.
  # for use as real rootfs. Alpine is great for sidecars but still not
  # for desktop.
  add_kasm
  $APTINSTALL  \
           i3 dbus-x11 desktop-base libdbus-glib-1-2 \
          kitty i3status rofi  alttab d-feet  \
          libinput-tools kbd \
          libnotify-bin fonts-font-awesome 

  add_chrome

  video_perms
}

# Both host and VM/container.
add_chrome() {
  # requires gnupg
  DEBIAN_FRONTEND=noninteractive apt install --assume-yes --no-install-recommends \
        gnupg
  curl https://dl-ssl.google.com/linux/linux_signing_key.pub | gpg --dearmor > /tmp/packages.google.gpg

  install -D -o root -g root -m 644 /tmp/packages.google.gpg /etc/apt/keyrings/packages.google.gpg
  echo "deb [arch=amd64,arm64,armhf signed-by=/etc/apt/keyrings/packages.google.gpg]  http://dl.google.com/linux/chrome/deb/ stable main" >> /etc/apt/sources.list.d/google-chrome.list
  apt update

  # Required for encrypted secrets support
  DEBIAN_FRONTEND=noninteractive apt install --assume-yes --no-install-recommends \
          gnome-keyring upower

  # Chrome (for isolated env)
  # Must happen after curl is installed
  # ~100M
  apt-get -y -q install google-chrome-stable
  #--no-install-recommends
}

####################

## Apt packages required for building kernel
# This is the base of 'dev' images.
kernel_build_tools() {
  apt update
  $APTINSTALL \
    ca-certificates                             \
    bc                                          \
    bison                                       \
    flex                                        \
    gcc                                         \
    git                                         \
    make                                        \
    libelf-dev \
    libssl-dev \
    erofs-utils \
    lz4 kmod ncurses-dev \
    python3 gawk xz-utils g++ zstd musl-tools

  # Used for signing, build
  $APTINSTALL curl gpg

  # If rust is not yet installed
  if ! command -v cargo > /dev/null; then 
    $APTINSTALL rustup
    rustup default stable
    rustup target add x86_64-unknown-linux-musl x86_64-unknown-uefi
    rustup component add clippy
    rustup component add rustfmt
    rustup component add rust-src
    rustup component add cargo
  fi  
  #rustc rust-src bindgen rustfmt rust-clippy cargo
  # For initos signing, testing
  $APTINSTALL age minisign cpio xxd file sbsigntool efitools genimage mtools swtpm cryptsetup-bin e2fsprogs
  $APTINSTALL qemu-system-x86
}

# Generic dev machine, common tools.
add_dev_tools() {
  kernel_build_tools

  $APTINSTALL \
        patch file \
       build-essential libc6-dev gawk g++ ripgrep


  # rg - codex likes it
  # TODO: maybe install zed too?
  #curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh

  # AVOID:     autoconf  automake libtool
}

